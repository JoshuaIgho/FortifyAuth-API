# Server Configuration
PORT=4000
NODE_ENV=development

# Database Configuration
DATABASE_URL="postgresql://user:password@localhost:5432/fortifyauth?schema=public"

# Redis Configuration
REDIS_URL="redis://localhost:6379"

# JWT Configuration
JWT_ACCESS_SECRET="your_super_secret_access_token_key_change_me"
JWT_REFRESH_SECRET="your_super_secret_refresh_token_key_change_me"
JWT_ACCESS_EXPIRY="15m"
JWT_REFRESH_EXPIRY="7d"

# Email Configuration
SMTP_HOST="smtp.example.com"
SMTP_PORT=587
SMTP_USER="your_smtp_user"
SMTP_PASS="your_smtp_password"
SMTP_FROM="noreply@fortifyauth.com"

# App Configuration
APP_URL="http://localhost:3000"
FRONTEND_URL="http://localhost:5173"
