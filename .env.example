# Server Configuration
PORT=3000
NODE_ENV=production

# Database Configuration (Render Managed PostgreSQL)
DATABASE_URL="postgresql://user:password@hostname:port/dbname?sslmode=require"

# Redis Configuration (Render Managed Redis)
REDIS_URL="rediss://user:password@hostname:port"

# JWT Configuration (Min 32 characters random string)
JWT_ACCESS_SECRET="your_super_secret_access_token_key_change_me"
JWT_REFRESH_SECRET="your_super_secret_refresh_token_key_change_me"
# Optional legacy variable
JWT_SECRET="your_super_secret_general_key_change_me"

# Expiry Settings
JWT_ACCESS_EXPIRY="15m"
JWT_REFRESH_EXPIRY="7d"

# Email Configuration (SMTP Provider)
SMTP_HOST="smtp.example.com"
SMTP_PORT=587
SMTP_USER="your_smtp_user"
SMTP_PASS="your_smtp_password"
SMTP_FROM="noreply@yourdomain.com"

# App Configuration
APP_URL="https://your-app-name.onrender.com"
FRONTEND_URL="https://your-app-name.onrender.com"
